{
  "version": "2.0",

  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },

  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },

  "extensions": {
    "serviceBus": {
      "messageProcessingOptions": {

        "autoCompleteMessages": true,
        "maxConcurrentCalls": 1,
        "maxMessageBatchSize": 100,
        "prefetchCount": 0

      }
    }
  }
}

