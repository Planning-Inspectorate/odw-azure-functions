{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Error",
      "Function": "Warning",
      "Host.Results": "Warning",
      "Host.Aggregator": "Warning",
      "Microsoft": "Warning",
      "Azure": "Warning",
      "azure": "Warning",
      "azure.core": "Warning",
      "azure.identity": "Warning",
      "azure.storage": "Warning",
      "azure.servicebus": "Warning"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}