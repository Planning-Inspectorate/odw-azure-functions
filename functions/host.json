{
  "version": "2.0",

  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },

  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.0.0, 5.0.0)"
  },

  "extensions": {
    "serviceBus": {
      "ProcessingOptions": {
        "maxConcurrentCalls": 8,
        "autoCompleteMessages": true,
        "maxAutoLockRenewalDuration": "00:05:00"
      }
    }
  }
}